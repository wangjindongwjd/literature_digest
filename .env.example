# ===============================================
# PubMed Literature Daily Digest - Configuration
# ===============================================
# Copy to .env:  copy .env.example .env
# Then edit .env with your settings.

# --- Email provider (qq / gmail / 163 / outlook) ---
EMAIL_PROVIDER=qq

# --- Or set SMTP manually ---
# SMTP_SERVER=smtp.qq.com
# SMTP_PORT=465
# SMTP_USE_SSL=true

# --- Your email credentials (REQUIRED) ---
SENDER_EMAIL=your_email@qq.com
SENDER_PASSWORD=your_smtp_auth_code_here
RECEIVER_EMAIL=your_email@qq.com,another@example.com

# --- PubMed search keyword ---
PUBMED_QUERY=pollination
# Examples:
# PUBMED_QUERY="meta analysis"
# PUBMED_QUERY="meta-analysis"[Publication Type]
# PUBMED_QUERY=cancer AND (immunotherapy OR CAR-T)

# --- Max papers per run ---
# PUBMED_RETMAX=50

# --- Translation (true = English + Chinese) ---
TRANSLATE_ENABLED=false

# --- Email subject ---
EMAIL_SUBJECT=📬 Daily Literature Digest - {date}

# --- Email branding (customize per instance) ---
BRAND_TITLE=Daily Literature Digest
BRAND_EMOJI=📬
BRAND_KEYWORD=pollination
BRAND_EMPTY_MSG=No new papers today.
