# ===============================================
# 传粉方向 PubMed 文献日报 - 环境变量配置
# ===============================================
# 复制此文件为 .env 并填入你的信息
# .env 不会被上传到 Git

# --- 邮箱提供商（选一个，会自动匹配 SMTP 设置） ---
# 可选: qq / gmail / 163 / outlook
EMAIL_PROVIDER=qq

# --- 或手动指定 SMTP ---
# SMTP_SERVER=smtp.qq.com
# SMTP_PORT=465
# SMTP_USE_SSL=true

# --- 邮箱账号（必填） ---
SENDER_EMAIL=your_email@qq.com
SENDER_PASSWORD=your_smtp_auth_code_here
RECEIVER_EMAIL=your_email@qq.com,another@example.com

# --- PubMed 检索 ---
# PUBMED_QUERY=pollination
# PUBMED_RETMAX=50

# --- 翻译（true 开启中英双语，false 仅英文）---
# TRANSLATE_ENABLED=false

# --- 邮件主题 ---
# EMAIL_SUBJECT=📬 传粉方向文献日报 - {date}

